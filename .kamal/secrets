# Secrets defined here are available for reference under registry/password, env/secret, builder/secrets,
# and accessories/*/env/secret in config/deploy.yml. All secrets should be pulled from either
# password manager, ENV, or a file. DO NOT ENTER RAW CREDENTIALS HERE! This file needs to be safe for git.
#
# This file works both locally and in CI:
#   - Locally: config/master.key and .kamal/db_password exist (gitignored); the
#     registry password comes from the logged-in GitHub CLI.
#   - In CI: the deploy workflow writes config/master.key and .kamal/db_password
#     from GitHub Actions secrets, and the registry password comes from the
#     Actions GITHUB_TOKEN (gh is not authenticated there, so it falls through).

# Rails master key — from the gitignored config/master.key.
RAILS_MASTER_KEY=$(cat config/master.key)

# PostgreSQL password — from the gitignored file .kamal/db_password. Both names
# resolve the same secret: the accessory initializes the cluster with
# POSTGRES_PASSWORD and the app reads HACKATHON_IFM_DATABASE_PASSWORD.
POSTGRES_PASSWORD=$(cat .kamal/db_password)
HACKATHON_IFM_DATABASE_PASSWORD=$(cat .kamal/db_password)

# Container registry (ghcr.io) — the logged-in GitHub CLI token locally
# (needs write:packages scope), or the Actions GITHUB_TOKEN in CI.
KAMAL_REGISTRY_PASSWORD=$(gh auth token 2>/dev/null || printf %s "$KAMAL_REGISTRY_PASSWORD")

ANTHROPIC_API_KEY=$(cat .kamal/api)

