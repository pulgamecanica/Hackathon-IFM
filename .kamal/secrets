# Secrets defined here are available for reference under registry/password, env/secret, builder/secrets,
# and accessories/*/env/secret in config/deploy.yml. All secrets should be pulled from either
# password manager, ENV, or a file. DO NOT ENTER RAW CREDENTIALS HERE! This file needs to be safe for git.

# Rails master key — read from the (gitignored) master.key on the deploy machine.
RAILS_MASTER_KEY=$(cat config/master.key)

# Container registry (ghcr.io) — uses the locally logged-in GitHub CLI token.
# Make sure `gh auth status` is green on the machine you deploy from.
KAMAL_REGISTRY_PASSWORD=$(gh auth token)

# PostgreSQL password — read from the gitignored file .kamal/db_password.
# Both names point at the same secret: the accessory uses POSTGRES_PASSWORD to
# initialize the cluster, and the app reads HACKATHON_IFM_DATABASE_PASSWORD.
POSTGRES_PASSWORD=$(cat .kamal/db_password)
HACKATHON_IFM_DATABASE_PASSWORD=$(cat .kamal/db_password)
