<% sentiment_styles = {
     "positive" => ["😊", "text-emerald-300 border-emerald-500/30 bg-emerald-500/10"],
     "neutral"  => ["😐", "text-slate-300 border-slate-500/30 bg-slate-500/10"],
     "negative" => ["😞", "text-rose-300 border-rose-500/30 bg-rose-500/10"],
     "mixed"    => ["🤔", "text-amber-300 border-amber-500/30 bg-amber-500/10"],
   } %>
<% emoji, badge = sentiment_styles[ai_insight.sentiment] || ["•", "text-slate-300"] %>

<div id="<%= dom_id(ai_insight) %>"
     class="rounded-xl border border-slate-800 bg-slate-900/60 p-4">
  <div class="flex items-start justify-between gap-3">
    <p class="text-sm text-slate-200"><%= ai_insight.summary %></p>
    <span class="shrink-0 rounded-full border px-2 py-0.5 text-xs font-medium <%= badge %>">
      <%= emoji %> <%= ai_insight.sentiment %>
    </span>
  </div>

  <% if ai_insight.key_themes.present? %>
    <div class="mt-3 flex flex-wrap gap-1.5">
      <% ai_insight.key_themes.split(", ").each do |theme| %>
        <span class="rounded-full bg-slate-800 px-2 py-0.5 text-xs text-slate-300"><%= theme %></span>
      <% end %>
    </div>
  <% end %>

  <div class="mt-3 flex flex-wrap items-center gap-3 text-xs text-slate-500">
    <% ai_insight.ratings.by_dimension(:overall).group_by(&:product_id).each do |_, ratings| %>
      <span class="text-slate-400">
        <%= ratings.first.product.name %>:
        <span class="text-violet-300 font-medium"><%= number_with_precision(ratings.first.score, precision: 1) %>★</span>
      </span>
    <% end %>
    <span class="ml-auto">conf <%= (ai_insight.confidence * 100).round %>% &middot; <%= ai_insight.model_version %></span>
  </div>
</div>
