<%# Subscribes to the broadcast channel; every ingest/analysis pushes updates here. %>
<%= turbo_stream_from "feedback_stream" %>

<% content_for :head do %>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
        integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
          integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
<% end %>

<div class="min-h-screen bg-white text-neutral-900">
  <%# ---- Masthead ---- %>
  <header class="border-b border-neutral-900">
    <div class="mx-auto max-w-7xl px-6 py-8">
      <div class="flex items-center justify-between text-[10px] uppercase tracking-[0.3em] text-neutral-500">
        <span><%= l(Date.current, format: :long) rescue Date.current.strftime("%d %B %Y") %></span>
        <span class="flex items-center gap-2">
          <span class="h-1.5 w-1.5 rounded-full bg-neutral-900 animate-pulse"></span>Live
        </span>
      </div>
      <div class="mt-6 text-center">
        <h1 class="font-serif text-6xl sm:text-7xl font-light tracking-[0.35em] pl-[0.35em]">LUMA</h1>
        <p class="mt-3 text-[11px] uppercase tracking-[0.45em] text-neutral-500">Feedback Intelligence</p>
      </div>
    </div>
  </header>

  <main class="mx-auto max-w-7xl px-6 py-12 space-y-14">
    <%= render "dashboard/stats", stats: @stats %>

    <%# ---- Map ---- %>
    <section>
      <div class="mb-5 flex items-end justify-between border-b border-neutral-200 pb-3">
        <h2 class="text-[11px] uppercase tracking-[0.28em] text-neutral-500">The Atelier — by Location</h2>
        <div class="flex items-center gap-4 text-[10px] uppercase tracking-[0.2em] text-neutral-500">
          <span class="flex items-center gap-1.5"><span class="h-2 w-2 rounded-full grad-positive"></span>Positive</span>
          <span class="flex items-center gap-1.5"><span class="h-2 w-2 rounded-full grad-neutral"></span>Neutral</span>
          <span class="flex items-center gap-1.5"><span class="h-2 w-2 rounded-full grad-negative"></span>Negative</span>
        </div>
      </div>
      <div data-controller="map" data-map-url-value="<%= map_data_path %>"
           class="relative border border-neutral-200 bg-white overflow-hidden">
        <button type="button" data-action="map#toggleFullscreen" data-map-target="fullscreenButton"
                class="absolute top-3 right-3 z-[1000] flex items-center gap-1.5 border border-neutral-300
                       bg-white/90 px-3 py-1.5 text-[10px] uppercase tracking-[0.2em] text-neutral-700
                       hover:border-neutral-900 hover:text-neutral-900 transition">
          <span data-map-target="fullscreenIcon">⛶</span>
          <span data-map-target="fullscreenLabel">Fullscreen</span>
        </button>
        <div data-map-target="canvas" class="h-80 w-full z-0"></div>
      </div>
    </section>

    <%= render "dashboard/analytics", insights: @insights %>

    <%= render "dashboard/chat" %>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
      <section>
        <h2 class="mb-5 border-b border-neutral-200 pb-3 text-[11px] uppercase tracking-[0.28em] text-neutral-500">Incoming Feedback</h2>
        <div id="feed" class="divide-y divide-neutral-200 border-y border-neutral-200">
          <% @raw_feedbacks.each do |raw_feedback| %>
            <%= render "dashboard/raw_feedback", raw_feedback: raw_feedback %>
          <% end %>
        </div>
      </section>

      <section>
        <h2 class="mb-5 border-b border-neutral-200 pb-3 text-[11px] uppercase tracking-[0.28em] text-neutral-500">AI Insights</h2>
        <div id="insights" class="divide-y divide-neutral-200 border-y border-neutral-200">
          <% @ai_insights.each do |ai_insight| %>
            <%= render "dashboard/ai_insight", ai_insight: ai_insight %>
          <% end %>
        </div>
      </section>
    </div>
  </main>

  <footer class="border-t border-neutral-900 mt-16">
    <div class="mx-auto max-w-7xl px-6 py-8 text-center text-[10px] uppercase tracking-[0.3em] text-neutral-400">
      LUMA — Paris · London · Tokyo
    </div>
  </footer>
</div>
