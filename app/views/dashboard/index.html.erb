<%# Subscribes to the broadcast channel; every ingest/analysis pushes updates here. %>
<%= turbo_stream_from "feedback_stream" %>

<% content_for :head do %>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
        integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
          integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
<% end %>

<div class="min-h-screen bg-slate-950 text-slate-100">
  <header class="border-b border-slate-800 bg-slate-900/60 backdrop-blur">
    <div class="mx-auto max-w-7xl px-6 py-5 flex items-center justify-between">
      <div>
        <h1 class="text-xl font-semibold tracking-tight">Feedback Intelligence</h1>
        <p class="text-sm text-slate-400">Real-time ingestion &middot; AI insights &middot; product ratings</p>
      </div>
      <div class="flex items-center gap-2 text-sm">
        <span class="relative flex h-2.5 w-2.5">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-emerald-500"></span>
        </span>
        <span class="text-slate-300">Live</span>
      </div>
    </div>
  </header>

  <main class="mx-auto max-w-7xl px-6 py-8 space-y-8">
    <%= render "dashboard/stats", stats: @stats %>

    <section>
      <div class="mb-3 flex items-center justify-between">
        <h2 class="text-sm font-medium uppercase tracking-wider text-slate-400">Feedback by Location</h2>
        <div class="flex items-center gap-3 text-xs text-slate-500">
          <span class="flex items-center gap-1"><span class="h-2.5 w-2.5 rounded-full" style="background:#34d399"></span>positive</span>
          <span class="flex items-center gap-1"><span class="h-2.5 w-2.5 rounded-full" style="background:#94a3b8"></span>neutral</span>
          <span class="flex items-center gap-1"><span class="h-2.5 w-2.5 rounded-full" style="background:#fb7185"></span>negative</span>
        </div>
      </div>
      <div data-controller="map" data-map-url-value="<%= map_data_path %>"
           class="relative rounded-xl border border-slate-800 overflow-hidden bg-slate-900">
        <button type="button" data-action="map#toggleFullscreen" data-map-target="fullscreenButton"
                class="absolute top-3 right-3 z-[1000] flex items-center gap-1.5 rounded-lg border border-slate-700
                       bg-slate-900/80 px-2.5 py-1.5 text-xs font-medium text-slate-200 backdrop-blur
                       hover:bg-slate-800 hover:border-slate-600 transition">
          <span data-map-target="fullscreenIcon">⛶</span>
          <span data-map-target="fullscreenLabel">Fullscreen</span>
        </button>
        <div data-map-target="canvas" class="h-80 w-full z-0"></div>
      </div>
    </section>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <section>
        <h2 class="mb-3 text-sm font-medium uppercase tracking-wider text-slate-400">Incoming Feedback</h2>
        <div id="feed" class="space-y-3">
          <% @raw_feedbacks.each do |raw_feedback| %>
            <%= render "dashboard/raw_feedback", raw_feedback: raw_feedback %>
          <% end %>
          <p class="empty:block hidden text-slate-500 text-sm">Waiting for feedback…</p>
        </div>
      </section>

      <section>
        <h2 class="mb-3 text-sm font-medium uppercase tracking-wider text-slate-400">AI Insights</h2>
        <div id="insights" class="space-y-3">
          <% @ai_insights.each do |ai_insight| %>
            <%= render "dashboard/ai_insight", ai_insight: ai_insight %>
          <% end %>
        </div>
      </section>
    </div>
  </main>
</div>
