<%# Replaced in place on every ingest/analysis via DashboardBroadcaster.refresh. %>
<div id="stats">
  <div class="grid grid-cols-2 md:grid-cols-5 divide-x divide-y md:divide-y-0 divide-neutral-200 border border-neutral-200">
    <% [
         ["Feedback", stats.total_feedback, ""],
         ["Processed", stats.processed, ""],
         ["In Queue", stats.pending, ""],
         ["Insights", stats.insights, ""],
         ["Avg Rating", stats.average_overall ? number_with_precision(stats.average_overall, precision: 2) : "—",
          stats.average_overall ? "text-grad-satisfaction" : ""],
       ].each do |label, value, value_class| %>
      <div class="px-6 py-8 text-center">
        <div class="font-numeric text-4xl leading-none <%= value_class %>"><%= value %></div>
        <div class="mt-3 text-[10px] uppercase tracking-[0.25em] text-neutral-500"><%= label %></div>
      </div>
    <% end %>
  </div>

  <% if stats.sentiment_breakdown.any? %>
    <div class="mt-5 flex items-center gap-4">
      <span class="text-[10px] uppercase tracking-[0.25em] text-neutral-500 shrink-0">Sentiment</span>
      <%
        shades = { "positive" => "grad-positive", "neutral" => "grad-neutral",
                   "negative" => "grad-negative", "mixed" => "grad-mixed" }
        total = stats.sentiment_breakdown.values.sum.to_f
      %>
      <div class="flex h-1.5 grow overflow-hidden">
        <% stats.sentiment_breakdown.each do |label, count| %>
          <div class="<%= shades[label] || "grad-neutral" %> h-full"
               style="width: <%= (count / total * 100).round %>%" title="<%= label %>: <%= count %>"></div>
        <% end %>
      </div>
      <span class="text-[10px] uppercase tracking-[0.25em] text-neutral-400 shrink-0"><span class="font-numeric"><%= stats.synthetic_share %></span>% Synthetic</span>
    </div>
  <% end %>
</div>
