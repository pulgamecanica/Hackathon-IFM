<%# Root id MUST be dom_id so FeedbackAnalysisJob can replace this card on completion. %>
<% status_styles = {
     "pending"    => ["Pending", "text-neutral-400"],
     "processing" => ["Analyzing", "text-neutral-500 animate-pulse"],
     "processed"  => ["Processed", "text-neutral-900"],
     "failed"     => ["Failed", "text-neutral-900 line-through"],
   } %>
<% label, badge = status_styles[raw_feedback.processing_status] %>

<div id="<%= dom_id(raw_feedback) %>" class="py-5 px-1 transition hover:bg-neutral-50">
  <div class="flex items-start justify-between gap-4">
    <p class="text-[15px] leading-relaxed text-neutral-800 font-serif"><%= raw_feedback.content %></p>
    <span class="shrink-0 text-[10px] uppercase tracking-[0.2em] <%= badge %>"><%= label %></span>
  </div>
  <div class="mt-3 flex flex-wrap items-center gap-x-3 gap-y-1 text-[10px] uppercase tracking-[0.18em] text-neutral-400">
    <span><%= raw_feedback.channel %></span>
    <% if raw_feedback.synthetic? %><span>· Synthetic</span><% end %>
    <% raw_feedback.products.each do |product| %>
      <span class="text-neutral-600">· <%= product.name %></span>
    <% end %>
    <span class="ml-auto"><%= time_ago_in_words(raw_feedback.submitted_at || raw_feedback.created_at) %> ago</span>
  </div>
</div>
