<%# Root id MUST be dom_id so FeedbackAnalysisJob can replace this card on completion. %>
<% status_styles = {
     "pending"    => ["Pending", "bg-amber-500/15 text-amber-300 border-amber-500/30"],
     "processing" => ["Analyzing", "bg-sky-500/15 text-sky-300 border-sky-500/30 animate-pulse"],
     "processed"  => ["Processed", "bg-emerald-500/15 text-emerald-300 border-emerald-500/30"],
     "failed"     => ["Failed", "bg-rose-500/15 text-rose-300 border-rose-500/30"],
   } %>
<% label, badge = status_styles[raw_feedback.processing_status] %>

<div id="<%= dom_id(raw_feedback) %>"
     class="rounded-xl border border-slate-800 bg-slate-900/60 p-4 transition hover:border-slate-700">
  <div class="flex items-start justify-between gap-3">
    <p class="text-sm text-slate-200 leading-relaxed"><%= raw_feedback.content %></p>
    <span class="shrink-0 rounded-full border px-2 py-0.5 text-xs font-medium <%= badge %>"><%= label %></span>
  </div>
  <div class="mt-3 flex flex-wrap items-center gap-2 text-xs text-slate-500">
    <span class="rounded bg-slate-800 px-1.5 py-0.5"><%= raw_feedback.channel %></span>
    <% if raw_feedback.synthetic? %>
      <span class="rounded bg-violet-500/15 text-violet-300 px-1.5 py-0.5">synthetic</span>
    <% end %>
    <% raw_feedback.products.each do |product| %>
      <span class="rounded bg-slate-800 px-1.5 py-0.5"><%= product.name %></span>
    <% end %>
    <span class="ml-auto"><%= time_ago_in_words(raw_feedback.submitted_at || raw_feedback.created_at) %> ago</span>
  </div>
</div>
